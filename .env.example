# ── 서버 설정 ──────────────────────────────────────────────────────────────────
# HTTP 서버 포트 (기본값: 3000)
PORT=3000

# ── 브라우저 설정 ───────────────────────────────────────────────────────────────
# 시스템에 설치된 Chrome/Chromium 실행 파일 경로
# 설정하지 않으면 Playwright 관리 바이너리 → Windows 기본 경로 순으로 자동 탐색
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# ── Phase 1 설정 ────────────────────────────────────────────────────────────────
# 탐지된 트리거 후보 중 실제로 실행할 최대 수 (기본값: 10)
MAX_TRIGGERS=16

# 동시 트리거 탐색 워커 수 (기본값: 4) — 값이 클수록 빠르지만 메모리/CPU 사용 증가
MAX_PARALLEL_WORKERS=8

# 트리거 스크린샷 모드 (기본값: changedRegion)
#   fullPage       — before(전체) + after(전체) + 어노테이션 오버레이  (비용 높음)
#   viewport       — after(뷰포트) + 어노테이션 사본               (빠름)
#   changedRegion  — after(뷰포트) + 변경 노드 유니온 bbox 클립     (기본, 권장)
#   element        — changedRegion 과 동일 (향후 요소 수준 확장 예비)
TRIGGER_SCREENSHOT_MODE=fullPage
# 패시브 자동 동적 영역 감지 (기본값: true)
# false 로 설정하면 감지를 건너뜀 (관찰 대기 시간도 생략됨)
DETECT_AUTO_DYNAMIC=true

# 자동 동적 영역 감지를 위해 사용자 상호작용 없이 관찰하는 시간 (기본값: 3000ms)
AUTO_DYNAMIC_OBSERVATION_MS=3000

# 트리거 후보가 자동 동적 영역과 겹치는 비율 임계값 (기본값: 0.3 = 30%)
# 이 값을 초과하면 해당 후보는 자동 동적 영역 내부로 판단하여 제외됨
AUTO_DYNAMIC_OVERLAP_THRESHOLD=0.3

# 트리거 실행 중 CSS 애니메이션 일시 정지 (기본값: false)
# true 로 설정하면 배경 애니메이션으로 인한 노이즈 뮤테이션 감소
# 분류 기반 제외를 대체하지 않음 — 함께 사용 권장
FREEZE_CSS_TRIGGERS=false
# ── Phase 3 설정 ────────────────────────────────────────────────────────────────
# 페이지당 수집할 URL 최대 수 (기본값: 50)
MAX_URLS=50

# 도달 가능성 사전 검사를 실행할 URL 최대 수 (기본값: 20)
MAX_CHECKS=20

# 외부 도메인 URL도 큐에 포함할지 여부 (기본값: false)
# true 로 설정하면 same-origin / same-site 외에 external URL도 수집됨
INCLUDE_EXTERNAL=false

# ── DOM 노드 필터 설정 ──────────────────────────────────────────────────────────
# 정적 노드로 유지할 최소 텍스트 길이 (기본값: 3)
NODE_MIN_TEXT=3

# 정적 노드로 유지할 최소 가시 면적 px² (기본값: 200)
NODE_MIN_AREA=200

# 일반 태그(div, span 등)에 적용하는 품질 점수 임계값 (기본값: 3)
# 이 값 미만이면 일반 태그는 제거됨 (HIGH_VALUE_TAGS는 항상 유지)
NODE_MIN_SCORE=3

# true 로 설정하면 filtered-node-debug.json 저장 (기본값: false)
DEBUG_NODES=false
