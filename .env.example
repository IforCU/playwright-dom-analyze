# ── 서버 설정 ──────────────────────────────────────────────────────────────────
# HTTP 서버 포트 (기본값: 3000)
PORT=3000

# ── 브라우저 설정 ───────────────────────────────────────────────────────────────
# 시스템에 설치된 Chrome/Chromium 실행 파일 경로
# 설정하지 않으면 Playwright 관리 바이너리 → Windows 기본 경로 순으로 자동 탐색
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# ── Phase 1 설정 ────────────────────────────────────────────────────────────────
# 스크린샷에 어노테이션 박스를 그릴 최대 노드 개수 (기본값: 400)
# 요소(노드)가 너무 많으면 박스가 겹쳐서 이미지를 알아보기 힘들고, 랜더링이 매우 느려집니다.
ANNOTATION_LIMIT=800

# 탐지된 트리거 후보 중 실제로 실행할 최대 수 (기본값: 10)
MAX_TRIGGERS=16

# 동시 트리거 탐색 워커 수 (기본값: 4) — 값이 클수록 빠르지만 메모리/CPU 사용 증가
MAX_PARALLEL_WORKERS=8

# 트리거 스크린샷 모드 (기본값: changedRegion)
#   fullPage       — before(전체) + after(전체) + 어노테이션 오버레이  (비용 높음)
#   viewport       — after(뷰포트) + 어노테이션 사본               (빠름)
#   changedRegion  — after(뷰포트) + 변경 노드 유니온 bbox 클립     (기본, 권장)
#   element        — changedRegion 과 동일 (향후 요소 수준 확장 예비)
TRIGGER_SCREENSHOT_MODE=changedRegion
# 패시브 자동 동적 영역 감지 (기본값: true)
# false 로 설정하면 감지를 건너뜀 (관찰 대기 시간도 생략됨)
DETECT_AUTO_DYNAMIC=true

# 자동 동적 영역 감지를 위해 사용자 상호작용 없이 관찰하는 시간 (기본값: 3000ms)
AUTO_DYNAMIC_OBSERVATION_MS=5000

# 트리거 후보가 자동 동적 영역과 겹치는 비율 임계값 (기본값: 0.3 = 30%)
# 이 값을 초과하면 해당 후보는 자동 동적 영역 내부로 판단하여 제외됨
AUTO_DYNAMIC_OVERLAP_THRESHOLD=0.3

# 트리거 실행 중 CSS 애니메이션 일시 정지 (기본값: false)
# true 로 설정하면 배경 애니메이션으로 인한 노이즈 뮤테이션 감소
# 분류 기반 제외를 대체하지 않음 — 함께 사용 권장
FREEZE_CSS_TRIGGERS=false

# ── 트리거 렌더링 대기 설정 ────────────────────────────────────────────────────────
# 트리거 액션 후 DOM 뮤테이션이 완전히 끝날 때까지 지능적으로 기다립니다.
# 고정된 sleep(2000ms) 대신 MutationObserver 버퍼를 폴링하여
# 실제 렌더링 완료 시점을 감지합니다.
#
# 동작 원리:
#   1. TRIGGER_INITIAL_MS 초기 대기 (첫 뮤테이션이 도착할 시간 확보)
#   2. 150ms 간격으로 뮤테이션 카운트 폴링
#   3. TRIGGER_QUIET_MS 동안 카운트 변화 없음 → 렌더링 완료로 판단, 즉시 진행
#   4. TRIGGER_SETTLE_MAX_MS 초과 시 강제 종료 (안전장치)
#   5. 네트워크 idle 추가 대기 (비동기 fetch 콘텐츠 로드 완료 보장)

# 트리거 액션 후 최초 폴링 시작까지 기다리는 시간 (기본값: 200ms)
TRIGGER_INITIAL_MS=200

# 이 시간 동안 새 뮤테이션이 없으면 렌더링 완료로 판단 (기본값: 600ms)
TRIGGER_QUIET_MS=600

# 뮤테이션 대기 최대 시간 (기본값: 5000ms) — 무거운 페이지도 이 시간 내 진행
TRIGGER_SETTLE_MAX_MS=5000

# 뮤테이션 안정화 후 네트워크 idle 추가 대기 타임아웃 (기본값: 2500ms)
# 트리거가 비동기 fetch를 발생시킬 때 로드된 콘텐츠도 캡처됨
TRIGGER_NETWORK_MS=2500

# ── 트리거 네비게이션 인증 감지 설정 ─────────────────────────────────────────────
# 트리거 클릭 후 페이지 이탈이 발생했을 때, 목적지를 분류합니다:
#   navigated_to_in_scope_page      — 동일 호스트, 일반 콘텐츠 페이지
#   navigated_to_login_same_host    — 동일 호스트, 로그인 페이지로 판단
#   navigated_to_login_auth_host    — 외부 호스트, 인증 공급자(IdP/OAuth)로 판단
#   navigated_out_of_scope          — 외부 호스트, 인증과 관련 없는 이탈
#   navigated_to_unknown            — 판단 근거 불충분
#
# 분류는 URL 경로, 쿼리 파라미터, 페이지 제목, 텍스트, 폼 구조 신호를 합산한
# 가중치 점수(heuristic) 로 이루어집니다. 사이트별 도메인 목록을 사용하지 않습니다.

# 트리거 네비게이션 인증 감지 활성화 (기본값: true)
# false 로 설정하면 감지를 건너뛰고 legacy 'navigated_away' 분류와 동일하게 동작
AUTH_DETECTION_ENABLED=true

# 인증 가능성 점수 임계값 — 이 값 이상이면 'auth-likely' (기본값: 5)
# 낮추면 더 많은 페이지를 인증 페이지로 분류 (false positive 증가)
AUTH_SCORE_THRESHOLD=5

# 인증 가능성 점수 중간 임계값 — 이 값 이상이면 'maybe-auth' (기본값: 3)
# 동일 호스트 + maybe-auth → navigated_to_login_same_host
# 외부 호스트 + maybe-auth → navigated_to_unknown
AUTH_MAYBE_THRESHOLD=3

# ── 초기 페이지 안정화 설정 ─────────────────────────────────────────────────────────
# Phase 1 기준선 캡처 전에 차단 UI를 감지하고 제거합니다.
# 처리 대상: 모달 팝업, 쿠키 동의 배너, 전체 화면 광고, 앱 설치 프롬프트,
#            자동 재생 영상 오버레이, 뉴스레터 구독 팝업, 로그인 월 등
#
# 단계별 전략:
#   Stage 1 — 오버레이 내부의 안전한 닫기/건너뛰기 버튼 클릭
#   Stage 2 — Escape 키 시도 (대부분의 모달 프레임워크 지원)
#   Stage 3 — 자동 재생 동영상/오디오 일시 정지 및 음소거
#   Stage 4 — 고신뢰도 차단 요소에 한해 CSS visibility:hidden 적용 (분석 컨텍스트 전용)
#
# 안전 원칙: 구매, 로그인, 설치, 폼 제출 등 탐색 가능성이 있는 버튼은 절대 클릭하지 않습니다.

# 초기 페이지 안정화 활성화 (기본값: true)
# false 로 설정하면 안정화 단계를 완전히 건너뜀
STABILIZE_PAGE=true

# 차단 요소로 판단하는 뷰포트 커버리지 임계값 (기본값: 0.30 = 30%)
# 너무 낮으면 작은 sticky 헤더도 차단 요소로 오탐될 수 있음
STABILIZE_COVERAGE_THRESHOLD=0.30

# 차단 요소로 판단하는 최소 z-index (기본값: 50)
# 너무 낮으면 일반 sticky 요소가 차단 요소로 오탐될 수 있음
STABILIZE_MIN_ZINDEX=50
# ── Phase 3 설정 ────────────────────────────────────────────────────────────────
# 페이지당 수집할 URL 최대 수 (기본값: 50)
MAX_URLS=50

# 도달 가능성 사전 검사를 실행할 URL 최대 수 (기본값: 20)
MAX_CHECKS=20

# 외부 도메인 URL도 큐에 포함할지 여부 (기본값: false)
# true 로 설정하면 same-origin / same-site 외에 external URL도 수집됨
INCLUDE_EXTERNAL=false

# ── DOM 노드 필터 설정 ──────────────────────────────────────────────────────────
# 정적 노드로 유지할 최소 텍스트 길이 (기본값: 3)
NODE_MIN_TEXT=3

# 정적 노드로 유지할 최소 가시 면적 px² (기본값: 200)
NODE_MIN_AREA=200

# 일반 태그(div, span 등)에 적용하는 품질 점수 임계값 (기본값: 3)
# 이 값 미만이면 일반 태그는 제거됨 (HIGH_VALUE_TAGS는 항상 유지)
NODE_MIN_SCORE=3

# true 로 설정하면 filtered-node-debug.json 저장 (기본값: false)
DEBUG_NODES=false
