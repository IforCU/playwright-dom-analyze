# ── 의존성 ────────────────────────────────────────────────────────────────────
node_modules/

# ── 환경 변수 ──────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── 분석 결과물 ────────────────────────────────────────────────────────────────
outputs/

# ── 그래프 상태 (런타임 아티팩트, 로컬에서 유지) ────────────────────────────────────
# data/page-graph.json 은 실행 간에 유지되는 로컬 아티팩트입니다.
# 팀 공유가 필요한 경우 이 줄을 제거하세요.
data/page-graph.json

# ── 인증 상태 파일 ─────────────────────────────────────────────────────────────
# storageState JSON 파일에 쿠키·세션 정보가 포함될 수 있으므로 커밋하지 않음
storage-states/*.json

# ── Playwright 브라우저 바이너리 ────────────────────────────────────────────────
.local-chromium/
.local-firefox/
.local-webkit/

# ── OS 및 에디터 ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.idea/

# ── 로그 ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
